FROM php:8.3-cli

WORKDIR /var/www/html

RUN apt-get update \
    && apt-get install -y --no-install-recommends git unzip libzip-dev default-mysql-client \
    && docker-php-ext-install pdo_mysql zip \
    && rm -rf /var/lib/apt/lists/*

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

COPY . .

RUN composer install --no-interaction --prefer-dist --optimize-autoloader

CMD composer install --no-interaction --prefer-dist \
    && until php artisan migrate --force; do echo "DB not ready, retrying in 3s..."; sleep 3; done \
    && php artisan db:seed --force \
    && php artisan serve --host=0.0.0.0 --port=8000
